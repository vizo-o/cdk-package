{
  "name": "@vizo-o/cdk-package",
  "version": "0.1.3",
  "exports": {
    "./constructs": {
      "types": "./dist/lib/constructs/index.d.ts",
      "default": "./dist/lib/constructs/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "release": "release-it",
    "release:ci": "release-it --ci",
    "postinstall": "node -e \"var p=require('path'),fs=require('fs'); var target=p.join(process.cwd(),'node_modules/aws-cdk-lib/node_modules/minimatch'); var src=p.join(process.cwd(),'node_modules/minimatch'); if(fs.existsSync(target) && fs.existsSync(src)) { fs.rmSync(target,{recursive:true}); fs.cpSync(src,target,{recursive:true}); }\""
  },
  "peerDependencies": {
    "aws-cdk-lib": "2.240.0",
    "constructs": "^10.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.10.1",
    "aws-cdk": "2.1105.0",
    "aws-cdk-lib": "2.240.0",
    "constructs": "10.5.0",
    "jest": "^29.7.0",
    "minimatch": "10.2.3",
    "release-it": "^19.2.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.0.0",
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-ssm": "^3.0.0",
    "source-map-support": "^0.5.21"
  },
  "description": "CDK constructs and utilities for Vizo infrastructure",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vizo-o/cdk-package.git"
  },
  "author": "Gilaad Elstein",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vizo-o/cdk-package/issues"
  },
  "homepage": "https://github.com/vizo-o/cdk-package#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "overrides": {
    "minimatch": "10.2.3",
    "ajv": "8.18.0",
    "fast-xml-parser": "5.3.8",
    "braces": "3.0.3",
    "undici": ">=6.24.0",
    "aws-cdk-lib": {
      "minimatch": "10.2.3"
    }
  }
}
