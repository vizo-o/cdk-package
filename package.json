{
    "name": "@vizo-o/cdk-package",
    "version": "0.1.11",
    "exports": {
        "./constructs": {
            "types": "./dist/lib/constructs/index.d.ts",
            "default": "./dist/lib/constructs/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "test": "jest",
        "cdk": "cdk",
        "lint": "eslint lib test --max-warnings=0 && prettier --check \"lib/**/*.{ts,json}\" \"test/**/*.{ts,json}\" \"*.{json,mjs}\" \"eslint.config.mjs\"",
        "lint:fix": "eslint lib test --fix --max-warnings=0 && prettier --write \"lib/**/*.{ts,json}\" \"test/**/*.{ts,json}\" \"*.{json,mjs}\" \"eslint.config.mjs\"",
        "type-check": "tsc --noEmit",
        "audit:high": "npm audit --audit-level=high",
        "pre-release": "node scripts/pre-release.mjs",
        "release": "release-it",
        "release:ci": "npm run pre-release && release-it --ci",
        "postinstall": "node scripts/patch-aws-cdk-nested-minimatch.mjs"
    },
    "peerDependencies": {
        "aws-cdk-lib": "^2.245.0",
        "constructs": "^10.5.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/jest": "^29.5.14",
        "@types/node": "22.10.1",
        "@typescript-eslint/eslint-plugin": "^8.18.2",
        "@typescript-eslint/parser": "^8.18.2",
        "@vizo-o/dev-tools": "^1.0.50",
        "aws-cdk": "2.1114.1",
        "aws-cdk-lib": "2.245.0",
        "constructs": "10.5.0",
        "eslint": "^9.17.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-promise": "^7.2.1",
        "globals": "^15.14.0",
        "jest": "^29.7.0",
        "brace-expansion": "5.0.5",
        "minimatch": "10.2.3",
        "prettier": "^3.4.2",
        "release-it": "^19.2.4",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "~5.7.2"
    },
    "dependencies": {
        "@aws-sdk/client-cognito-identity-provider": "^3.0.0",
        "@aws-sdk/client-lambda": "^3.0.0",
        "@aws-sdk/client-secrets-manager": "^3.0.0",
        "@aws-sdk/client-ssm": "^3.0.0",
        "source-map-support": "^0.5.21"
    },
    "description": "CDK constructs and utilities for Vizo infrastructure",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vizo-o/cdk-package.git"
    },
    "author": "Gilaad Elstein",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/vizo-o/cdk-package/issues"
    },
    "homepage": "https://github.com/vizo-o/cdk-package#readme",
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "overrides": {
        "brace-expansion": "5.0.5",
        "minimatch": "10.2.3",
        "fast-xml-parser": ">=5.5.7",
        "braces": "3.0.3",
        "undici": ">=6.24.0",
        "aws-cdk-lib": {
            "minimatch": "10.2.3"
        }
    }
}
